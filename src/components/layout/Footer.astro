---
import { menuLinks, siteConfig } from "@/site.config";

const year = new Date().getFullYear();
---

<footer
	class="text-muted mt-auto flex w-full flex-col items-center justify-center gap-y-2 pt-20 pb-4 text-center align-top sm:flex-row sm:justify-between sm:text-xs"
>
	<div class="me-0 font-normal sm:me-4">
		&copy; {year} - All rights reserved by {siteConfig.author}.
		<span class="inline-block">
			&nbsp;Built with <a class="hover:text-global-text underline" href="https://astro.build/" target="_blank">Astro</a
			>
			and the <a
				class="hover:text-global-text underline"
				href="https://github.com/chrismwilliams/astro-theme-cactus"
				target="_blank">Cactus</a
			> theme.
		</span>
	</div>
	<nav aria-labelledby="footer_links" class="sm:divide-muted flex gap-x-2 sm:gap-x-0 sm:divide-x">
		<p id="footer_links" class="sr-only">More on this site</p>
		{
			menuLinks.map((link) => (
				<a class="hover:text-global-text px-4 py-2 font-semibold hover:underline sm:py-0" href={link.path}>
					{link.title}
				</a>
			))
		}
	</nav>
</footer>
